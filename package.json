{
  "name": "chakbox-ui",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/xuqiyong666/chakbox-ui"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "tsc": "tsc"
  },
  "peerDependencies": {
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@emotion/serialize": "^1.3.3",
    "@types/lodash": "^4.17.16",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
